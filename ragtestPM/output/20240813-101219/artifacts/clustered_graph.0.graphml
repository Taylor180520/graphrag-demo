    </node>
    <node id="&quot;RELEVANT COST OF MATERIAL Z&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"The total relevant cost of material Z is calculated by comparing three options: buying Z now and storing it, buying Z in one month&#8217;s time, or converting material Y. The lowest cost option is chosen."</data>
      <data key="d2">42cd34884f35d28c36f2156eefcb5c76</data>
      <data key="d4">0</data>
      <data key="d5">1391</data>
