    </node>
    <node id="&quot;ENVIRONMENTAL FAILURE COSTS QUIZ&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">"The quiz tests knowledge on categorizing environmental failure costs, such as compensation payments, air pollution, and penalties for breaching environmental regulations."</data>
      <data key="d2">c072010f60f9a31fe566e35a7ad7d3cc</data>
