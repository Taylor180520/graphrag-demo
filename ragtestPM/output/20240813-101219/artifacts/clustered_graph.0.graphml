    <edge source="&quot;MARGINAL COSTING&quot;" target="&quot;PERIOD COSTS&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Period costs are treated as expenses in the period in which they are incurred in marginal costing."</data>
      <data key="d11">b6aae482ada9c34bf0afb23a1a9ef1fa</data>
      <data key="d12">1378b3b72d1f4a50b8995d52f3be38ce</data>
