    <edge source="&quot;RETURN ON INVESTMENT FOR DIVISION D&quot;" target="&quot;REVISED PROFIT&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Revised profit for Division D is calculated as $280,000 + $25,000 (Profit on sale of old machinery) - $60,000 (Depreciation charge on new machinery) = $245,000."</data>
      <data key="d11">a5a7a3e9a59209ce811c1f9470684fa6</data>
      <data key="d12">ae2a0255b75446789843ce6ad5a65036</data>
