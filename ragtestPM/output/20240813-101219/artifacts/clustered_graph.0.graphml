    <node id="&quot;RETURN PER HOUR QUIZ&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">"This quiz tests the calculation of return per hour for a product using throughput accounting. It involves determining the return per hour based on selling price, material costs, conversion costs, and time on the bottleneck resource."</data>
      <data key="d2">bf895221917dacb42684c64f347d269d</data>
      <data key="d7">26</data>
