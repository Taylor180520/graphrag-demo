      <data key="d9">1.0</data>
      <data key="d10">"Management Information System (MIS) provides regular reports and summaries for tactical planning and control."</data>
      <data key="d11">d4fd6778c3735e1144e70c31e7a057e5</data>
      <data key="d12">cb4e7de151e54704afc62c946d9e2633</data>
