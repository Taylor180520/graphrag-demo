      <data key="d9">1.0</data>
      <data key="d10">"Factors such as manager attitudes, skills, and interdependence between departments influence the level of top-down budgeting."</data>
      <data key="d11">bba1095f6b9a360e21d80bc3dc45ff30</data>
      <data key="d12">3972f82aa81a469cab9ed6b9823c7eb4</data>
      <data key="d13">669</data>
