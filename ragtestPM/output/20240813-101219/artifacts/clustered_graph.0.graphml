    <edge source="&quot;OPPORTUNITY COST&quot;" target="&quot;RELEVANT COSTING PRINCIPLES&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Opportunity cost is a key component of Relevant costing principles as it represents the value of the best alternative foregone due to a decision."</data>
      <data key="d11">77d0f2f7f5d6dc47dd22962bc1f3d777</data>
      <data key="d12">c0b8cebca3244da0891aed0f2a527cef</data>
      <data key="d13">360</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;OPPORTUNITY COST&quot;" target="&quot;TRANSFER PRICE&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Opportunity cost is a component of the transfer price calculation for Division M."</data>
      <data key="d11">34f2c5c9d893c1b631ed1646193eebf4</data>
      <data key="d12">1a315dfbb6084fe181a8b6173ff11a64</data>
      <data key="d13">361</data>
      <data key="d14">0</data>
    </edge>
