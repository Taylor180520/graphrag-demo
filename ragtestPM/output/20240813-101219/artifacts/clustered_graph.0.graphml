    <node id="&quot;VALUE FOR MONEY FRAMEWORK&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"The value for money framework is used to monitor performance in terms of economy, efficiency, and effectiveness."</data>
