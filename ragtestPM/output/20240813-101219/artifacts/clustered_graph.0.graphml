      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Existing machinery for hormone process refers to the equipment and machinery that Sniff Co already owns and uses for the hormone-adding process during the test month."</data>
      <data key="d2">853a1c1f12ff5eee7a78129a3fed226f</data>
      <data key="d4">0</data>
      <data key="d5">2120</data>
      <data key="d6">bc01ff2959564e7db2f29caa94960458</data>
