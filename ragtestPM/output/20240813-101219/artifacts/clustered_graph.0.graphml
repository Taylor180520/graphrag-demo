    <edge source="&quot;USE OF INFORMATION IN CONTROL&quot;" target="&quot;STRATEGIC PLANNING AND CONTROL INFORMATION&quot;">
      <data key="d9">2.0</data>
      <data key="d10">"Strategic Planning and Control Information is used by strategic managers for long-term planning and control."</data>
      <data key="d11">d4fd6778c3735e1144e70c31e7a057e5</data>
      <data key="d12">06b6be805a6243eebc533375dbcd36a4</data>
      <data key="d13">20</data>
