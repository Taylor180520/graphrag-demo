      <data key="d6">fc86507186da4c6c94fe3b788d77c471</data>
    </node>
    <node id="&quot;SALES PRICE FOR A TYPICAL GC USING CURRENT METHOD&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"Price per unit using absorption cost plus 50%: Materials: $3,500, Labour (300 * 15): $4,500, Overheads (300 * ($400,000/40,000)): $3,000, Total cost: $11,000, Plus mark-up (50%): $5,500, Current price: $16,500."</data>
      <data key="d2">94bad6b839398ff56bb1fd1316fb6bc0</data>
      <data key="d7">0</data>
      <data key="d8">0</data>
      <data key="d4">2</data>
