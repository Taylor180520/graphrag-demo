    <node id="&quot;ORGANIZATIONAL GOALS&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Organizational goals are the strategic objectives that a company's management establishes to outline expected outcomes and guide employees' efforts."</data>
