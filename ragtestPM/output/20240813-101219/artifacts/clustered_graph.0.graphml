    <edge source="&quot;USE OF INFORMATION IN CONTROL&quot;" target="&quot;TACTICAL PLANNING AND CONTROL INFORMATION&quot;">
      <data key="d9">2.0</data>
      <data key="d10">"Tactical Planning and Control Information is used by tactical managers for efficient operation and control."</data>
      <data key="d11">d4fd6778c3735e1144e70c31e7a057e5</data>
      <data key="d12">6de28dc1838849779330476c1ac4cc13</data>
      <data key="d13">21</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;USE OF INFORMATION IN CONTROL&quot;" target="&quot;OPERATIONAL PLANNING AND CONTROL INFORMATION&quot;">
      <data key="d9">2.0</data>
      <data key="d10">"Operational Planning and Control Information is used by operational managers for detailed transactional control."</data>
      <data key="d11">d4fd6778c3735e1144e70c31e7a057e5</data>
      <data key="d12">4165827c54a6448d93db533177b4d9e2</data>
