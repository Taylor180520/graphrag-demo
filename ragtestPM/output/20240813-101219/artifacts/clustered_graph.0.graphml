    <node id="&quot;TOTAL MATERIAL COST VARIANCE&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"Total material cost variance is calculated as the sum of the material price variance and the material usage variance. In this case, it is $4,900A."</data>
      <data key="d2">b3b56fd239dac9dbd52c81d7357fc19b</data>
      <data key="d7">28</data>
      <data key="d8">0</data>
      <data key="d4">2</data>
