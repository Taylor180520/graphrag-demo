    </edge>
    <edge source="&quot;CONTROLLABLE PROFIT&quot;" target="&quot;NET PROFIT&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Net profit includes head office costs, whereas controllable profit excludes them, making controllable profit a more accurate measure for divisional performance."</data>
      <data key="d11">312c3cf9edbc058c6e810c1e9c9cd81a</data>
      <data key="d12">79244fdaf0bb4af8a9a0df6e00c83ec1</data>
