    </node>
    <node id="&quot;STATEMENT 4&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"There will always be one unique solution (e.g. production plan)."</data>
      <data key="d2">3ff25cf1ebad4d5b8f8a7bbfefd288ab</data>
