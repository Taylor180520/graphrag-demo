      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Non-financial assessment for further processing involves evaluating factors such as market acceptance, health concerns, and potential impact on the company's reputation."</data>
      <data key="d2">853a1c1f12ff5eee7a78129a3fed226f</data>
      <data key="d4">0</data>
      <data key="d5">2116</data>
      <data key="d6">301ab9bf0996482e8d7d5df34b9aaf78</data>
    </node>
    <node id="&quot;PERFUME PRODUCTION COSTS&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Perfume production costs refer to the expenses associated with creating the standard perfume, including raw materials, labour, and overhead costs."</data>
      <data key="d2">853a1c1f12ff5eee7a78129a3fed226f</data>
      <data key="d4">0</data>
      <data key="d5">2117</data>
      <data key="d6">ca3c5454f3ff438c83c30bef806d34cf</data>
    </node>
    <node id="&quot;HORMONE COSTS FOR MALE AND FEMALE VERSIONS&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Hormone costs for male and female versions refer to the expenses associated with adding specific hormones to the perfume for male and female customers."</data>
      <data key="d2">853a1c1f12ff5eee7a78129a3fed226f</data>
      <data key="d4">0</data>
      <data key="d5">2118</data>
      <data key="d6">1b9b343f81bb44828dbda7d91ea512ec</data>
    </node>
