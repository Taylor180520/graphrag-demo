      <data key="d5">1349</data>
      <data key="d6">a861f44aa7dd414790ee82b3f651c609</data>
    </node>
    <node id="&quot;BOTTLENECK IDENTIFICATION QUIZ&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">"This quiz involves identifying the bottleneck process in a manufacturing scenario with three consecutive processes: preparation, machining, and polishing. It requires calculating the maximum weekly output for each process to determine the bottleneck."</data>
      <data key="d2">bf895221917dacb42684c64f347d269d</data>
