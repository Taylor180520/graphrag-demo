    <node id="&quot;DEMAND PER PERIOD&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Demand per period refers to the number of units of a product that are required or expected to be sold in a given time period."</data>
      <data key="d2">cdba52ee4f0e2669ccb29b10b23e609a</data>
      <data key="d7">26</data>
