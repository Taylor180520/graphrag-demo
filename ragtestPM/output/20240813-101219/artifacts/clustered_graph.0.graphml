      <data key="d14">0</data>
    </edge>
    <edge source="&quot;TARGET COSTING&quot;" target="&quot;TARGET PROFIT&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"The concept of Target Costing involves calculating the Target Profit by dividing the total required profit by the number of units to be sold."</data>
      <data key="d11">9d54588af94d453794e574c052472b3e</data>
      <data key="d12">ee04dfe49c6c473d803f75032050c772</data>
      <data key="d13">191</data>
      <data key="d14">0</data>
    </edge>
