      <data key="d4">7</data>
      <data key="d5">1348</data>
      <data key="d6">b4fe3c6aea95472db73a5e8bf575895a</data>
    </node>
    <node id="&quot;ENVIRONMENTAL MANAGEMENT ACCOUNTING QUIZ&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">The "ENVIRONMENTAL MANAGEMENT ACCOUNTING QUIZ" is designed to test knowledge on various aspects of environmental management accounting (EMA). It includes questions that require participants to categorize fuel costs for a road haulage company under different cost categories, with the correct answer identifying conventional costs as the most appropriate category for fuel costs. Additionally, the quiz covers the purpose of EMA, the types of information it provides, the primary users of EMA information, and the types of data it encompasses.</data>
      <data key="d2">71a15e253f55633783cde51ebbef843e,bf895221917dacb42684c64f347d269d</data>
      <data key="d7">16</data>
      <data key="d8">0</data>
