      <data key="d9">2.0</data>
      <data key="d10">"Limiting Factor Decisions involve the use of Limiting Factor Analysis to determine the optimal production plan."</data>
      <data key="d11">e6f7ca658dc25c9178113951c7a31846</data>
      <data key="d12">20fa38bead00434daeb73b435b09fc65</data>
      <data key="d13">285</data>
      <data key="d14">0</data>
    </edge>
