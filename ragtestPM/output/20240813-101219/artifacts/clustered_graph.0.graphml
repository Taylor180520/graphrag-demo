    <edge source="&quot;INFORMATION&quot;" target="&quot;KNOWLEDGE&quot;">
      <data key="d9">3.0</data>
      <data key="d10">"Information" is analyzed to become "Knowledge." Information is comprehended and applied to become "Knowledge."</data>
      <data key="d11">75aa284e3bf8d3b64f3e1feff1c7b3fb,9cc1a2ea3eea29b6f534abb18ab94b2d</data>
