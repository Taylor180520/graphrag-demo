    </node>
    <node id="&quot;DISHWASHER (PRODUCT D)&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Product D is another product manufactured by the Large Appliances division, earning a contribution of $200 per unit."</data>
      <data key="d2">88e696361bcc111f3d87032d375208f9</data>
      <data key="d7">11</data>
      <data key="d8">0</data>
      <data key="d4">1</data>
      <data key="d5">1706</data>
      <data key="d6">ca58c4e2fae84899a780ff379e1927eb</data>
    </node>
    <node id="&quot;PRODUCTION CONSTRAINTS FOR PRODUCT F AND D&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"The production constraints for Product F and D are given by the formulas: Materials: 4F + 6D = 2500, Labour: 10F + 8D = 4000, Machine time: 5F + 10D = 3200, Demand for D: 250."</data>
      <data key="d2">88e696361bcc111f3d87032d375208f9</data>
      <data key="d7">11</data>
      <data key="d8">0</data>
      <data key="d4">4</data>
      <data key="d5">1707</data>
      <data key="d6">2060ce64f028490798a3ed69832e048d</data>
    </node>
    <node id="&quot;CONTRIBUTION PER UNIT OF LIMITING FACTOR FOR PRODUCT T&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"The contribution per unit of limiting factor for Product T is calculated as follows: Contribution per kg = $52 / 3 = $17.33."</data>
      <data key="d2">88e696361bcc111f3d87032d375208f9</data>
      <data key="d7">12</data>
      <data key="d8">0</data>
