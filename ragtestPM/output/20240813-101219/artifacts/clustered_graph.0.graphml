    <node id="&quot;ENVIRONMENTAL LIFE-CYCLE COSTING&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Environmental life-cycle costing considers environmental costs from the design stage of a product through to decommissioning at the end of its life."</data>
      <data key="d2">03721d9b5064cc002df514cca9896c3b</data>
