      <data key="d4">3</data>
      <data key="d5">72</data>
      <data key="d6">fa3c4204421c48609e52c8de2da4c654</data>
    </node>
    <node id="&quot;USER SUPPORT&quot;">
      <data key="d0">"FEATURES"</data>
      <data key="d1">"User support refers to the assistance provided to users of a system or software, including help desks, tutorials, and customer service."</data>
      <data key="d2">75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
      <data key="d4">1</data>
      <data key="d5">73</data>
      <data key="d6">53af055f068244d0ac861b2e89376495</data>
    </node>
    <node id="&quot;REPORTING FEATURES&quot;">
      <data key="d0">"FEATURES"</data>
      <data key="d1">"Reporting features in a CRM system allow users to generate reports on various metrics, such as sales performance, customer interactions, and service efficiency."</data>
      <data key="d2">75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
      <data key="d4">1</data>
      <data key="d5">74</data>
      <data key="d6">c03ab3ce8cb74ad2a03b94723bfab3c7</data>
    </node>
    <node id="&quot;TRACKING FEATURES&quot;">
      <data key="d0">"FEATURES"</data>
      <data key="d1">"Tracking features in a CRM system enable the monitoring of customer interactions, sales activities, and service requests to ensure timely follow-ups and resolution."</data>
      <data key="d2">75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
      <data key="d4">1</data>
      <data key="d5">75</data>
      <data key="d6">ed6d2eee9d7b4f5db466b1f6404d31cc</data>
    </node>
    <node id="&quot;DATA MODEL&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"A data model is a conceptual representation of the data structures that are required for a database and is used to define how data is connected and how it is processed and stored."</data>
      <data key="d2">75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
      <data key="d4">1</data>
      <data key="d5">76</data>
      <data key="d6">fc01e9baa80e417c9206f941bb279407</data>
