    <edge source="&quot;DATA&quot;" target="&quot;INFORMATION&quot;">
      <data key="d9">2.0</data>
      <data key="d10">"Data is processed to become information."</data>
      <data key="d11">75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
