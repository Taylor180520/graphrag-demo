      <data key="d9">3.0</data>
      <data key="d10">"Limiting Factor Analysis is the basis for the Quiz: Limiting Factor Analysis. The Quiz: Limiting Factor Analysis tests the understanding of Limiting Factor Analysis methodology."</data>
      <data key="d11">1f7a550d089ceb3dbcb11ef3bde8fa37,e6f7ca658dc25c9178113951c7a31846</data>
      <data key="d12">cc328fc8316d45fdb81690943562f5e8</data>
      <data key="d13">284</data>
      <data key="d14">0</data>
    </edge>
