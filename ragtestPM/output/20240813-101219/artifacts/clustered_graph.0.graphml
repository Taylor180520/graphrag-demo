    </edge>
    <edge source="&quot;TRANSFER PRICING&quot;" target="&quot;DIVISIONAL AUTONOMY&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"A transfer pricing system should support divisional autonomy while ensuring fair pricing."</data>
      <data key="d11">0622f4f26dbe7479c871198b2e72b940</data>
      <data key="d12">ca8ae1809a7248b38552454965715b4d</data>
      <data key="d13">1187</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;TRANSFER PRICING&quot;" target="&quot;SUPPLYING DIVISION PERSPECTIVE&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"The supplying division's perspective on transfer pricing includes considering marginal cost and opportunity cost."</data>
      <data key="d11">0622f4f26dbe7479c871198b2e72b940</data>
      <data key="d12">e50f2ee682624601bdb6ebf75a4d955b</data>
      <data key="d13">1188</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;TRANSFER PRICING&quot;" target="&quot;DIVISION B&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Transfer pricing affects Division B as it determines the revenue Division B earns from selling fittings to Division A."</data>
      <data key="d11">078e47b3223db97709a37da2a01302c5</data>
      <data key="d12">65a3165d30664f9db1cfa75856c87f12</data>
      <data key="d13">1189</data>
