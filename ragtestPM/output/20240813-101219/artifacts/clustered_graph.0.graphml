    <edge source="&quot;RETURN ON INVESTMENT FOR DIVISION D&quot;" target="&quot;REVISED ASSETS&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Revised assets for Division D is calculated as $2,000,000 - $100,000 (Old machinery) + $300,000 (New machinery) - $300,000 (cash paid for new machinery) &#8722; $60,000 (Depreciation charge on new machinery)."</data>
      <data key="d11">a5a7a3e9a59209ce811c1f9470684fa6</data>
      <data key="d12">129a03d0e82e4842b67bce5b77ce2fb2</data>
