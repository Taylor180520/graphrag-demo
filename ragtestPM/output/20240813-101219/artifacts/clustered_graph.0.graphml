    </node>
    <node id="&quot;THROUGHPUT CONTRIBUTION CALCULATION&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"Throughput contribution per metre = Selling price per metre - Material cost per metre. Throughput contribution per hour = Throughput contribution per metre * Metres per hour."</data>
      <data key="d2">c072010f60f9a31fe566e35a7ad7d3cc</data>
      <data key="d4">0</data>
      <data key="d5">1245</data>
      <data key="d6">d07207b853c14504a44eea1d4778f902</data>
    </node>
    <node id="&quot;LIFE CYCLE COSTING QUIZ&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">"The quiz tests knowledge on life cycle costing, focusing on identifying costs over a product's entire life cycle and calculating overall profitability."</data>
      <data key="d2">c072010f60f9a31fe566e35a7ad7d3cc</data>
      <data key="d7">2</data>
      <data key="d8">0</data>
      <data key="d4">1</data>
