    </node>
    <node id="&quot;SECURITY CONTROLS&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Security Controls are measures implemented within an organization to ensure the security of highly confidential information, including logical access controls, database controls, and hierarchical passwords."</data>
      <data key="d2">9cb3ca1f088473aac339bd044b8a7507</data>
