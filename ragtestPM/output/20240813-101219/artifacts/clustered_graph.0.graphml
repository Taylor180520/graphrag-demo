    <node id="&quot;VOICE ANALYTICS&quot;">
      <data key="d0">"FEATURES"</data>
      <data key="d1">"Voice analytics involves analyzing audio data to extract useful information, such as keywords and sentiment, similar to text analytics but with spoken language."</data>
      <data key="d2">75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
      <data key="d4">1</data>
      <data key="d5">79</data>
      <data key="d6">c6d1e4f56c2843e89cf0b91c10bb6de2</data>
    </node>
    <node id="&quot;CUSTOMER RELATIONSHIP MANAGEMENT SYSTEM (CRM)&quot;">
      <data key="d0" />
      <data key="d1">A Customer Relationship Management System (CRM) records the relationship between the enterprise and its customers, managing interactions and data throughout the customer lifecycle.</data>
      <data key="d2">2ad6c0ee81f4b0da1c6b2f2821dff6b6,75aa284e3bf8d3b64f3e1feff1c7b3fb</data>
