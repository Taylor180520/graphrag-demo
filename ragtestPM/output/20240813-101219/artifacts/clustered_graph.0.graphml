      <data key="d9">1.0</data>
      <data key="d10">"Executive Information System (EIS) provides high-level information for strategic planning and control."</data>
      <data key="d11">d4fd6778c3735e1144e70c31e7a057e5</data>
      <data key="d12">a1487ae4dc86472a8c022cbec6568fee</data>
      <data key="d13">24</data>
      <data key="d14">0</data>
    </edge>
