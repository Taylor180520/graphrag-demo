    <node id="&quot;ENVIRONMENTAL COST ACCOUNTING TECHNIQUES QUIZ&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">"This quiz evaluates knowledge of various management accounting techniques that can be used to account for environmental costs, including flow cost accounting, input/output analysis, life-cycle costing, and activity-based costing."</data>
      <data key="d2">bf895221917dacb42684c64f347d269d</data>
