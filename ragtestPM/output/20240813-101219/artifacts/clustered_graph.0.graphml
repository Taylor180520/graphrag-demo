    <node id="&quot;PRODUCTION LINE SETUP&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Production line setup involves preparing and configuring production equipment and processes for manufacturing. The budgeted cost for production line setup for the current period is $42,000."</data>
