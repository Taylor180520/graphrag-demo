    <node id="&quot;FREEZER (PRODUCT F)&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Product F is a product manufactured by the Large Appliances division, earning a contribution of $150 per unit."</data>
      <data key="d2">88e696361bcc111f3d87032d375208f9</data>
      <data key="d7">11</data>
      <data key="d8">0</data>
      <data key="d4">1</data>
