    <node id="&quot;TARGET COST REDUCTION&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"Target cost reduction involves identifying ways to reduce costs to meet a target cost that allows for an acceptable profit margin."</data>
