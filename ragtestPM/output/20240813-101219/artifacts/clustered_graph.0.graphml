      <data key="d5">1660</data>
      <data key="d6">4e581bc7d4424c2fb0023e5b11687e02</data>
    </node>
    <node id="&quot;ENTRY FEE&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"The fee charged for entry to the gym, which is $8.40."</data>
