      <data key="d6">7e2c84548fb94ee395ba8588d8f2a006</data>
    </node>
    <node id="&quot;PRODUCTION COSTS AND ACTIVITY CHANGES&quot;">
      <data key="d0">"CONCEPTS"</data>
      <data key="d1">"A production manager wants to understand how production costs respond to changes in activity."</data>
      <data key="d2">a65f7c228e32e13ec5bad9f87503b9c1</data>
      <data key="d3">"CONCEPTS"</data>
      <data key="d4">1</data>
      <data key="d5">100</data>
