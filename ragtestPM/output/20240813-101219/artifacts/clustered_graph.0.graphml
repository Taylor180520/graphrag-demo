      <data key="d12">2da7c30addce4314a6b7d656d102ce18</data>
      <data key="d13">192</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;TARGET COSTING&quot;" target="&quot;TARGET COST&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"The concept of Target Costing aims to determine the Target Cost by subtracting the target profit per unit from the target price."</data>
