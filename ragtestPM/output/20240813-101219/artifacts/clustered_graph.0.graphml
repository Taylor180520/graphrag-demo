      <data key="d9">2.0</data>
      <data key="d10">"Joint products are not separately identifiable until the split-off point in the production process."</data>
      <data key="d11">b172e19fb414304c0d4fa0f2db3a6499</data>
      <data key="d12">9c18e3095c1c4b589bae348a539db3d5</data>
      <data key="d13">403</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;JOINT PRODUCTS&quot;" target="&quot;FURTHER PROCESSING DECISION&quot;">
      <data key="d9">2.0</data>
      <data key="d10">"Further processing decisions involve joint products created from the same production process."</data>
      <data key="d11">b172e19fb414304c0d4fa0f2db3a6499</data>
      <data key="d12">3fa936635320477cbb990905f5db11d6</data>
      <data key="d13">404</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;JOINT PRODUCTS&quot;" target="&quot;SPLIT-OFF POINT&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Joint products are separated at the split-off point, where they can be recognized as separate products."</data>
      <data key="d11">f48e76ebf07d8d7de318d46534f42fd9</data>
      <data key="d12">616436c3a00f460e95a07c9e7e2a855d</data>
      <data key="d13">405</data>
      <data key="d14">0</data>
    </edge>
    <edge source="&quot;SPLIT-OFF POINT (SOP)&quot;" target="&quot;FURTHER PROCESSING DECISION&quot;">
      <data key="d9">2.0</data>
      <data key="d10">"The decision to further process a product is made after the split-off point."</data>
      <data key="d11">b172e19fb414304c0d4fa0f2db3a6499</data>
      <data key="d12">78ee453bcfa54aa5a48230b905ddfb0a</data>
      <data key="d13">406</data>
