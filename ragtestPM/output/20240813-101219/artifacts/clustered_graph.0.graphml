      <data key="d9">1.0</data>
      <data key="d10">"Transfer Pricing is designed to achieve the Objectives of Transfer Pricing."</data>
      <data key="d11">4e87d1e76027b0ff68b56a7c9c9c92c1</data>
      <data key="d12">45b445c1e01f40eaa8544b6d122091aa</data>
