      <data key="d9">2.0</data>
      <data key="d10">"The Example of Limiting Factor Identification illustrates the application of Limiting Factor Analysis."</data>
      <data key="d11">e6f7ca658dc25c9178113951c7a31846</data>
      <data key="d12">c6ff0a59b101488fa5a85fd8d6bd11fc</data>
      <data key="d13">286</data>
      <data key="d14">0</data>
    </edge>
