    </node>
    <node id="&quot;BUDGETED PRODUCTION COST&quot;">
      <data key="d0">"QUIZZES"</data>
      <data key="d1">"This quiz involves calculating the budgeted total production cost for Jessie Co, given estimates of variable and fixed costs at different production levels."</data>
      <data key="d2">8cf592364030d479cf1085a135ca8d22</data>
      <data key="d4">1</data>
      <data key="d5">1285</data>
