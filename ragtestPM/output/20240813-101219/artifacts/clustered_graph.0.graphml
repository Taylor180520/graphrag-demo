    </node>
    <node id="&quot;THROUGHPUT CONTRIBUTION PER UNIT OF LIMITING FACTOR&quot;">
      <data key="d0">"FORMULAS"</data>
      <data key="d1">"Throughput contribution per unit of limiting factor = Throughput contribution per unit / Units of limiting factor (minutes)"</data>
      <data key="d2">cdba52ee4f0e2669ccb29b10b23e609a</data>
      <data key="d7">12</data>
      <data key="d8">0</data>
