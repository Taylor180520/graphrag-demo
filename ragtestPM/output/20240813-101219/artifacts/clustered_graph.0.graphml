      <data key="d14">0</data>
    </edge>
    <edge source="&quot;FEEDBACK CONTROL&quot;" target="&quot;FEED-FORWARD CONTROL&quot;">
      <data key="d9">1.0</data>
      <data key="d10">"Feed-forward control addresses the limitations of feedback control by allowing proactive adjustments."</data>
